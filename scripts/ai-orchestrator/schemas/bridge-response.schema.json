{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://go-irl.local/schemas/bridge-response.schema.json",
  "title": "AI Orchestrator Bridge Response v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["success", "mission_id", "status", "next_action", "artifacts"],
  "properties": {
    "success": { "type": "boolean" },
    "mission_id": { "type": ["string", "null"] },
    "status": { "type": "string", "minLength": 1 },
    "next_action": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "success": { "const": false } } },
      "then": { "required": ["error"] },
      "else": { "not": { "required": ["error"] } }
    }
  ]
}
