{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://go-irl.local/schemas/context-pack.schema.json",
  "title": "AI Developer Context Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "source_of_truth_refs",
    "file_manifest",
    "grep_evidence",
    "constraints",
    "acceptance_criteria",
    "size_metadata",
    "secret_redaction"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "mission_id": { "type": "string", "pattern": "^MISSION-[A-Za-z0-9._-]+$", "maxLength": 120 },
    "source_of_truth_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/-]+$" }
    },
    "file_manifest": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/-]+$" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "grep_evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["query", "path", "line", "excerpt"],
        "properties": {
          "query": { "type": "string", "minLength": 1, "maxLength": 300 },
          "path": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/-]+$" },
          "line": { "type": "integer", "minimum": 1 },
          "excerpt": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_paths", "forbidden_paths", "no_dependency_addition", "no_architecture_rewrite"],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/*?-]+$" }
        },
        "forbidden_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/*?-]+$" }
        },
        "no_dependency_addition": { "const": true },
        "no_architecture_rewrite": { "const": true }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "size_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_count", "total_bytes", "max_bytes", "within_limit"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 1, "maximum": 50 },
        "total_bytes": { "type": "integer", "minimum": 0 },
        "max_bytes": { "type": "integer", "minimum": 1 },
        "within_limit": { "const": true }
      }
    },
    "secret_redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "findings", "redacted_fields"],
      "properties": {
        "status": { "enum": ["clean", "redacted"] },
        "findings": { "type": "array", "maxItems": 50, "items": { "type": "string", "minLength": 1, "maxLength": 500 } },
        "redacted_fields": { "type": "array", "maxItems": 50, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 300 } }
      }
    }
  }
}
