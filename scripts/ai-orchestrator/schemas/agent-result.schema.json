{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://go-irl.local/schemas/agent-result.schema.json",
  "title": "AI Developer Agent Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "role",
    "status",
    "evidence",
    "changed_files",
    "risks",
    "validation_errors",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "mission_id": { "type": "string", "pattern": "^MISSION-[A-Za-z0-9._-]+$", "maxLength": 120 },
    "role": { "type": "string", "minLength": 1, "maxLength": 120 },
    "status": { "type": "string", "enum": ["PASS", "CHANGES_REQUIRED", "BLOCKED"] },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "line", "claim"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/-]+$" },
          "line": { "type": "integer", "minimum": 1 },
          "claim": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/-]+$" }
    },
    "risks": { "type": "array", "maxItems": 50, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
    "validation_errors": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "path", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1, "maxLength": 120 },
          "path": { "type": "string", "minLength": 1, "maxLength": 500 },
          "message": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "next_action": { "type": "string", "minLength": 1, "maxLength": 1000 }
  }
}
