{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://go-irl.local/schemas/mission.schema.json",
  "title": "AI Developer Mission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "objective",
    "risk_level",
    "allowed_paths",
    "forbidden_paths",
    "acceptance_criteria",
    "maximum_budget_usd",
    "requires_human_approval",
    "source_of_truth_refs"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "mission_id": { "type": "string", "pattern": "^MISSION-[A-Za-z0-9._-]+$", "maxLength": 120 },
    "objective": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/*?-]+$",
        "allOf": [
          { "not": { "pattern": "(?:^|/)(?:[Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh][Ee][Nn][Tt][Ii][Cc][Aa][Tt][Ii][Oo][Nn])(?:/|$)" } },
          { "not": { "pattern": "(?:^|/)[Rr][Ll][Ss](?:/|$)" } },
          { "not": { "pattern": "(?:^|/)[Ss][Qq][Ll](?:/|$)|\\.[Ss][Qq][Ll]$" } },
          { "not": { "pattern": "(?:^|/)[Mm][Ii][Gg][Rr][Aa][Tt][Ii][Oo][Nn][Ss]?(?:/|$)" } },
          { "not": { "pattern": "(?:^|/)(?:[Dd][Ee][Pp][Ll][Oo][Yy](?:[Mm][Ee][Nn][Tt])?|[Vv][Ee][Rr][Cc][Ee][Ll])(?:/|$)|(?:^|/)[Vv][Ee][Rr][Cc][Ee][Ll]\\.[Jj][Ss][Oo][Nn]$|(?:^|/)\\.[Vv][Ee][Rr][Cc][Ee][Ll](?:/|$)|(?:^|/)[Dd][Ee][Pp][Ll][Oo][Yy][Mm][Ee][Nn][Tt]\\.[Mm][Dd]$" } },
          { "not": { "pattern": "(?:^|/)[Pp][Rr][Oo][Dd][Uu][Cc][Tt][Ii][Oo][Nn][-_]?[Dd][Aa][Tt][Aa](?:/|$)" } },
          { "not": { "pattern": "(?:^|/)(?:[Ss][Ee][Cc][Rr][Ee][Tt][Ss]?|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?)(?:/|$)" } }
        ]
      }
    },
    "forbidden_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/*?-]+$" }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "maximum_budget_usd": { "type": "number", "minimum": 0.01, "maximum": 5 },
    "requires_human_approval": { "const": true },
    "source_of_truth_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:[./*]|$))[A-Za-z0-9._/-]+$" }
    }
  }
}
