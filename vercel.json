{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": true
  },
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "corepack enable pnpm && pnpm install --frozen-lockfile",
  "framework": "vite",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':(exclude)docs/**' ':(exclude)**/*.md'",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "{assets/share-backgrounds/webp/**,assets/event-backgrounds/share-6x5/**}"
    }
  },
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
