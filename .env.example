# Supabase - required in production
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Telegram Mini App links
VITE_GO_IRL_BOT_USERNAME=GOirl_bot
VITE_GO_IRL_APP_NAME=

# DEV/DEMO ONLY. VITE_* values are public in the frontend bundle.
# Do not put real production admin identifiers here.
VITE_GO_IRL_ADMIN_KEYS=telegram:123456789,telegram_username:yourusername

# DEV/DEMO ONLY. Keep false for public production.
VITE_GO_IRL_LEGACY_DEMO_AUTH=false

# Optional local build marker. Vercel should set this automatically.
VITE_GIT_COMMIT=abc1234

# Edge Function secret. Set in Supabase Dashboard, not in frontend production env.
GO_IRL_JWT_SECRET=your_legacy_jwt_secret

# Server-only Meta messaging integration. Configure in Vercel, never as VITE_* values.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
META_GRAPH_VERSION=v23.0
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_random_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_LIFECYCLE_TEMPLATE_NAME=go_irl_event_update
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_professional_account_id
MESSENGER_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
MESSENGER_PAGE_ID=your_facebook_page_id
